# ─── Google / Firebase ───────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Opsiyonel: Premium Google Cloud TTS (Metin-to-Ses) için Google Cloud JSON servis hesabı dosya yolu
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ─── External APIs ───────────────────────────────────────────────────────────
YOUTUBE_DATA_API_KEY=your_youtube_api_key_here
UDEMY_CLIENT_ID=your_udemy_client_id
UDEMY_CLIENT_SECRET=your_udemy_client_secret
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
